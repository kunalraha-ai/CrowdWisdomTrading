# OpenRouter API Key (required for Hermes LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Apify API Token (required for Meta Ad Library and Influencer scraping)
APIFY_API_TOKEN=your_apify_api_token_here

# Custom Meta Ads Scraper Actor ID (e.g., curious_coder/facebook-ads-library-scraper)
APIFY_META_ADS_ACTOR_ID=curious_coder/facebook-ads-library-scraper

# Custom Instagram Profile Scraper Actor ID (e.g., apify/instagram-profile-scraper)
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-profile-scraper

# Custom YouTube Scraper Actor ID (e.g., streamers/youtube-scraper)
APIFY_YOUTUBE_ACTOR_ID=streamers/youtube-scraper

# Telegram Bot Token (optional, for Telegram Gateway setup)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Enable verbose plugin logging
HERMES_PLUGINS_DEBUG=1
